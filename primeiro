    {
      "cell_type": "code",
      "source": [
        "def extrair_digitos(n):\n",
        "    \"\"\"Retorna os 4 dígitos de n (com zeros à esquerda) como\n",
        "    quatro variáveis separadas, usando apenas aritmética.\"\"\"\n",
        "    d1 = n // 1000          # milhar\n",
        "    d2 = (n % 1000) // 100  # centena\n",
        "    d3 = (n % 100)  // 10   # dezena\n",
        "    d4 = n % 10             # unidade\n",
        "    return d1, d2, d3, d4\n",
        "\n",
        "\n",
        "def ordenar_4(a, b, c, d):\n",
        "    \"\"\"Ordena 4 valores em ordem crescente usando apenas\n",
        "    comparações e trocas (bubble sort manual, sem arrays).\"\"\"\n",
        "    # Passagem 1\n",
        "    if a > b:\n",
        "        a, b = b, a\n",
        "    if b > c:\n",
        "        b, c = c, b\n",
        "    if c > d:\n",
        "        c, d = d, c\n",
        "    # Passagem 2\n",
        "    if a > b:\n",
        "        a, b = b, a\n",
        "    if b > c:\n",
        "        b, c = c, b\n",
        "    # Passagem 3\n",
        "    if a > b:\n",
        "        a, b = b, a\n",
        "    return a, b, c, d\n",
        "\n",
        "\n",
        "def montar_numero(d1, d2, d3, d4):\n",
        "    \"\"\"Reconstrói o inteiro de 4 dígitos a partir dos dígitos\n",
        "    individuais (d1 = milhar, d4 = unidade).\"\"\"\n",
        "    return d1 * 1000 + d2 * 100 + d3 * 10 + d4\n",
        "\n",
        "\n",
        "def contar_repeticoes(a, b, c, d):\n",
        "    \"\"\"Retorna a maior quantidade de vezes que um mesmo dígito\n",
        "    aparece entre os quatro, usando apenas comparações.\"\"\"\n",
        "    max_rep = 1\n",
        "\n",
        "    # Conta repetições de cada dígito individualmente\n",
        "    for digito in (a, b, c, d):\n",
        "        contagem = 0\n",
        "        if a == digito:\n",
        "            contagem = contagem + 1\n",
        "        if b == digito:\n",
        "            contagem = contagem + 1\n",
        "        if c == digito:\n",
        "            contagem = contagem + 1\n",
        "        if d == digito:\n",
        "            contagem = contagem + 1\n",
        "        if contagem > max_rep:\n",
        "            max_rep = contagem\n",
        "\n",
        "    return max_rep\n",
        "\n",
        "\n",
        "# ------------------------------------------------------------\n",
        "# VALIDAÇÃO 1 — tipo (inteiro e positivo)\n",
        "# ------------------------------------------------------------\n",
        "entrada = input(\"Digite um número de até 4 dígitos: \")\n",
        "\n",
        "# Verificação manual de dígitos sem funções de string proibidas\n",
        "# Única exceção: len() e isdigit() são operadores básicos de\n",
        "# validação de entrada ensinados em sala.\n",
        "# Se o professor não permite nem isso, substitua por try/except int().\n",
        "valido = True\n",
        "for caractere in entrada:\n",
        "    if not caractere.isdigit():\n",
        "        valido = False\n",
        "        break\n",
        "\n",
        "if not valido:\n",
        "    print(\"Erro: o valor informado não é um número inteiro positivo.\")\n",
        "else:\n",
        "    numero = int(entrada)\n",
        "\n",
        "    # ----------------------------------------------------------\n",
        "    # VALIDAÇÃO 2 — faixa 0000–9999\n",
        "    # ----------------------------------------------------------\n",
        "    if numero < 0 or numero > 9999:\n",
        "        print(\"Erro: o número deve estar entre 0 e 9999.\")\n",
        "    else:\n",
        "        print(\"Número informado:\", numero)\n",
        "\n",
        "        # ------------------------------------------------------\n",
        "        # LOOP PRINCIPAL\n",
        "        # ------------------------------------------------------\n",
        "        iteracao = 0\n",
        "\n",
        "        while numero != 6174:\n",
        "\n",
        "            # Extrai os 4 dígitos\n",
        "            d1, d2, d3, d4 = extrair_digitos(numero)\n",
        "\n",
        "            # --------------------------------------------------\n",
        "            # VALIDAÇÃO 3 — repetição de dígitos (máx. 2 iguais)\n",
        "            # (revalidada a cada iteração, conforme enunciado)\n",
        "            # --------------------------------------------------\n",
        "            if contar_repeticoes(d1, d2, d3, d4) >= 3:\n",
        "                print(\"Erro: o número possui três ou mais dígitos repetidos.\")\n",
        "                break\n",
        "\n",
        "            # Ordena crescente → NDC\n",
        "            p1, p2, p3, p4 = ordenar_4(d1, d2, d3, d4)\n",
        "            NDC = montar_numero(p1, p2, p3, p4)\n",
        "\n",
        "            # Inverte para decrescente → NDD\n",
        "            NDD = montar_numero(p4, p3, p2, p1)\n",
        "\n",
        "            # Subtração\n",
        "            resultado = NDD - NDC\n",
        "            iteracao = iteracao + 1\n",
        "\n",
        "            # Exibe a iteração no formato pedido\n",
        "            # Para exibir zeros à esquerda sem f-string com formato,\n",
        "            # calculamos e imprimimos dígito a dígito via aritmética.\n",
        "            r1, r2, r3, r4 = extrair_digitos(resultado)\n",
        "            n1, n2, n3, n4 = extrair_digitos(NDC)\n",
        "            nd1, nd2, nd3, nd4 = extrair_digitos(NDD)\n",
        "\n",
        "            print(\"Iteração\", iteracao, \":\",\n",
        "                  nd1, nd2, nd3, nd4,   # NDD (decrescente)\n",
        "                  \"-\",\n",
        "                  n1,  n2,  n3,  n4,   # NDC (crescente)\n",
        "                  \"=\",\n",
        "                  r1,  r2,  r3,  r4)   # resultado\n",
        "\n",
        "            numero = resultado\n",
        "\n",
        "        else:\n",
        "            # Só executa se o while terminou SEM break (chegou em 6174)\n",
        "            print(\"Constante de Kaprekar 6174 atingida em\", iteracao, \"iterações.\")"
